# Neon Postgres — auto-set when you add the Neon integration in Vercel
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob — auto-set when you add Blob storage in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=""

# Optional — required for forgot-password emails in production
RESEND_API_KEY=""
EMAIL_FROM="StillHere <noreply@yourdomain.com>"
